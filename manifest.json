{
  "manifest_version": 3,
  "name": "Buscador Inteligente IA",
  "version": "1.1",
  "description": "Busca productos inteligentemente con IA en cualquier página web",

  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "Buscador IA - Haz clic para buscar"
  },

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}